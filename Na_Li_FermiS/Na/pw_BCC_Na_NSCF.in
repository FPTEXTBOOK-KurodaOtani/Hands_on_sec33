&CONTROL
 calculation = 'nscf' 
 prefix = 'scf' 
 pseudo_dir = '/yourdir/PSPOT' 
 outdir = './data' 
 tprnfor = .true. 
 disk_io = 'non' 
/
&SYSTEM
 ibrav = 0 
 ecutwfc = 45 
 ecutrho = 450 
 occupations = 'smearing' 
 smearing = 'gaussian' 
 degauss = 0.02 
 nspin = 1 
 ntyp = 1 
 nat = 1 
/
&ELECTRONS
 electron_maxstep = 200 
 mixing_beta = 0.075 
 conv_thr = 1e-08 
/
&IONS
 ion_dynamics = 'bfgs' 
 upscale = 1.0 
/
&CELL
/
/
 
K_POINTS {automatic}
30 30 30 0 0 0
 
ATOMIC_SPECIES
Na 11 na_pbe_v1.5.uspp.F.UPF
 
CELL_PARAMETERS {angstrom}
  -2.094375830   2.094375830   2.094375830
   2.094375830  -2.094375830   2.094375830
   2.094375830   2.094375830  -2.094375830
 
ATOMIC_POSITIONS {crystal}
Na 0.00000000 0.00000000 0.00000000
