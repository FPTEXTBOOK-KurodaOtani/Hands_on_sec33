&CONTROL
 calculation = 'nscf' 
 prefix = 'scf' 
 pseudo_dir = '/yourdir/PSPOT' 
 outdir = './data' 
 tprnfor = .true. 
 disk_io = 'non' 
/
&SYSTEM
 ecutwfc = 45 
 ecutrho = 450 
 ibrav         = 0,
 occupations = 'smearing' 
 smearing = 'gaussian' 
 degauss = 0.02
 nspin = 1 
 ntyp = 1 
 nat = 1 
/
&ELECTRONS
 electron_maxstep = 200 
 mixing_beta = 0.075 
 conv_thr = 1e-08 
/
&IONS
 ion_dynamics = 'bfgs' 
 upscale = 1.0 
/
&CELL
/
/
 
 
ATOMIC_SPECIES
Li 3 li_pbe_v1.4.uspp.F.UPF
 

CELL_PARAMETERS {angstrom}
-1.7175 1.7175 1.7175
1.7175 -1.7175 1.7175
1.7175 1.7175 -1.7175

ATOMIC_POSITIONS {crystal}
Li 0.00000000 0.00000000 0.00000000

K_POINTS {automatic}
40 40 40 0 0 0
