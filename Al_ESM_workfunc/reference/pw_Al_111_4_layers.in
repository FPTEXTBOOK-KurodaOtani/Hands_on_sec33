&CONTROL
   calculation      = 'scf'
   restart_mode     = 'from_scratch'
   outdir           = './tmp/'
   prefix           = 'Al4'
   pseudo_dir       = '/yourdir/PSPOT/'
/
&SYSTEM
   ibrav            = 0
   ecutwfc          = 40
   ecutrho          = 400
   nosym            = .true.
   occupations      = 'smearing'
   degauss          = 0.01
   smearing         = 'mp'
   assume_isolated  = 'esm'
   esm_bc           = 'bc1'
   ntyp             = 1
   nat              = 4
/
&ELECTRONS
   conv_thr         = 1e-08
/
&IONS
/
&CELL
/
&FCP
/
&RISM
/
