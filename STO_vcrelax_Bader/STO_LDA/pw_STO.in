&CONTROL
   calculation      = 'vc-relax',
   prefix           = 'SrTiO3',
   outdir           = './out',
   pseudo_dir       = '/yourdir/PSPOT',
   tstress          = .true.,
   tprnfor          = .true.,
/

&SYSTEM
   ibrav            = 0,
   nat              = 5,
   ntyp             = 3,
   ecutwfc          = 70,
   ecutrho          = 700,
/

&ELECTRONS
   electron_maxstep = 200
   conv_thr         = 1.0d-8,
   mixing_beta      = 0.7,
/
&IONS
 ion_dynamics = 'bfgs'
 upscale = 1.0
/
&CELL
/
/


CELL_PARAMETERS angstrom
   3.892742093   0.000000000   0.000000000
   0.000000000   3.892742093   0.000000000
   0.000000000   0.000000000   3.892742093


ATOMIC_SPECIES
  Sr 87.62  sr_lda_v1.uspp.F.UPF             
  Ti 47.867 ti_lda_v1.4.uspp.F.UPF             
   O 15.999 o_lda_v1.2.uspp.F.UPF         

ATOMIC_POSITIONS crystal
  Sr  0.0000000  0.00000  0.000000
  Ti  0.500000  0.500000  0.500000
   O  0.500000  0.500000  0.000000
   O  0.500000  0.000000  0.500000
   O  0.000000  0.500000  0.500000

K_POINTS automatic
  10 10 10  0 0 0
