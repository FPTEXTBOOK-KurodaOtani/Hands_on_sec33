&CONTROL
 calculation = 'scf' 
 prefix = 'scf' 
 pseudo_dir = '/yourdir/PSPOT' 
 outdir = './data' 
 tprnfor = .true. 
 disk_io = 'non' 
/
&SYSTEM
 ibrav = 0 
 ecutwfc = 40.0 
 ecutrho = 400 
 occupations = 'smearing' 
 smearing = 'mp' 
 degauss = 0.01 
 nspin = 1 
 ntyp = 1 
 nat = 2 
/
&ELECTRONS
 electron_maxstep = 200 
 mixing_beta = 0.075 
 conv_thr = 1e-08 
/
&IONS
 ion_dynamics = 'bfgs' 
 upscale = 1.0 
/
&CELL
/
/
 
K_POINTS {automatic}
12 12 12 0 0 0
 
ATOMIC_SPECIES
Si 28 si_pbe_v1.uspp.F.UPF
 
CELL_PARAMETERS {angstrom}
0.00 2.73 2.73
2.73 0.00 2.73
2.73 2.73 0.00
 
ATOMIC_POSITIONS {crystal}
Si 0.00000000 0.00000000 0.00000000
Si 0.25000000 0.25000000 0.25000000
