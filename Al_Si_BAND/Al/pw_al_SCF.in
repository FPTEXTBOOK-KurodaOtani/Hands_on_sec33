&CONTROL
 calculation = 'scf' 
 prefix = 'scf' 
 pseudo_dir = '/yourdir/PSPOT' 
 outdir = './data' 
 tprnfor = .true. 
 disk_io = 'non' 
/
&SYSTEM
 ibrav = 0 
 ecutwfc = 40.0 
 ecutrho = 400 
 occupations = 'smearing' 
 smearing = 'mp' 
 degauss = 0.01 
 nspin = 1 
 ntyp = 1 
 nat = 1 
/
&ELECTRONS
 electron_maxstep = 200 
 mixing_beta = 0.075 
 conv_thr = 1e-08 
/
&IONS
 ion_dynamics = 'bfgs' 
 upscale = 1.0 
/
&CELL
/
/
 
K_POINTS {automatic}
12 12 12 0 0 0
 
ATOMIC_SPECIES
Al 13 al_pbe_v1.uspp.F.UPF
 
CELL_PARAMETERS {angstrom}
0.00 2.02 2.02
2.02 0.00 2.02
2.02 2.02 0.00
 
ATOMIC_POSITIONS {crystal}
Al 0.00000000 0.00000000 0.00000000
